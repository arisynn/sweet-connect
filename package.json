{
  "name": "@workspace/sweet-connect",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint . || true",
    "dev": "node scripts/generateThemes.js && tsx server.ts",
    "build": "node scripts/generateThemes.js && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@babel/standalone": "^7.26.0",
    "@supabase/supabase-js": "^2.110.8",
    "acorn": "^8.17.0",
    "acorn-jsx": "^5.3.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@babel/plugin-syntax-jsx": "^7.25.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vite": "^7.3.2"
  }
}
